{
    "name": "@iqkv/multimoduleservice",
    "version": "0.0.0",
    "private": true,
    "description": "Provide an optional Git commit hooks.",
    "license": "Apache-2.0",
    "type": "module",
    "scripts": {
        "formatter:check": "oxfmt --check",
        "formatter:write": "oxfmt --write",
        "lint": "pnpm lint:stylelint && pnpm formatter:check",
        "lint:stylelint": "stylelint \"**/*.css\" --aei",
        "node_modules:cleanup": "rm -rf node_modules",
        "prepare": "husky",
        "release": "release-it --ci"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@release-it/conventional-changelog": "^11.0.1",
        "cz-conventional-changelog": "^3.3.0",
        "glob": "^13.0.6",
        "husky": "9.1.7",
        "lint-staged": "^17.0.7",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.67.0",
        "oxlint-tsgolint": "^0.23.0",
        "release-it": "^19.2.4",
        "release-it-pnpm": "^4.6.6",
        "sort-package-json": "^4.0.0",
        "stylelint": "^17.12.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "tsdown": "^0.22.1"
    },
    "lint-staged": {
        "*": [
            "pnpm formatter:check"
        ],
        "package.json": [
            "sort-package-json"
        ]
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "engines": {
        "node": ">=22.15.0"
    },
    "packageManager": "pnpm@11.0.8"
}
